# vigilant Monitor Environment Configuration
# 复制此文件为 .env 并修改相应配置

# ================================
# 应用基础配置
# ================================
GIN_MODE=release
KOMARI_LISTEN=0.0.0.0:25774

# ================================
# 数据库配置 - SQLite 模式
# ================================
# 使用 SQLite 数据库（适合小规模部署）
KOMARI_DB_TYPE=sqlite
KOMARI_DB_FILE=./data/komari.db

# ================================
# 数据库配置 - MySQL 模式
# ================================
# 使用 MySQL 数据库（推荐生产环境）
# 取消注释以下配置并注释掉上面的 SQLite 配置

# KOMARI_DB_TYPE=mysql
# KOMARI_DB_HOST=localhost
# KOMARI_DB_PORT=3306
# KOMARI_DB_USER=komari
# KOMARI_DB_PASS=your_secure_password
# KOMARI_DB_NAME=komari

# ================================
# MySQL 连接池配置（仅 MySQL 模式）
# ================================
# KOMARI_DB_MAX_IDLE_CONNS=10
# KOMARI_DB_MAX_OPEN_CONNS=100
# KOMARI_DB_CONN_MAX_LIFETIME=3600

# ================================
# 时区配置
# ================================
TZ=Asia/Shanghai

# ================================
# 日志配置
# ================================
# KOMARI_LOG_LEVEL=info
# KOMARI_LOG_FILE=./logs/komari.log
# KOMARI_LOG_MAX_SIZE=100
# KOMARI_LOG_MAX_BACKUPS=10
# KOMARI_LOG_MAX_AGE=30

# ================================
# 安全配置
# ================================
# KOMARI_JWT_SECRET=your_random_secret_key_here
# KOMARI_SESSION_SECRET=your_session_secret_key_here

# ================================
# OAuth 配置
# ================================
# KOMARI_OAUTH_GITHUB_CLIENT_ID=
# KOMARI_OAUTH_GITHUB_CLIENT_SECRET=
# KOMARI_OAUTH_GOOGLE_CLIENT_ID=
# KOMARI_OAUTH_GOOGLE_CLIENT_SECRET=

# ================================
# 通知配置
# ================================
# KOMARI_NOTIFICATION_TELEGRAM_BOT_TOKEN=
# KOMARI_NOTIFICATION_TELEGRAM_CHAT_ID=
# KOMARI_NOTIFICATION_SMTP_HOST=
# KOMARI_NOTIFICATION_SMTP_PORT=587
# KOMARI_NOTIFICATION_SMTP_USER=
# KOMARI_NOTIFICATION_SMTP_PASS=
# KOMARI_NOTIFICATION_SMTP_FROM=

# ================================
# 主题配置
# ================================
# KOMARI_THEME_DIR=./themes
# KOMARI_THEME_DEFAULT=default

# ================================
# GeoIP 配置
# ================================
# KOMARI_GEOIP_PROVIDER=ipinfo
# KOMARI_GEOIP_TOKEN=

# ================================
# 性能配置
# ================================
# KOMARI_RECORD_RETENTION_DAYS=30
# KOMARI_LONG_TERM_RETENTION_DAYS=365
# KOMARI_CLEANUP_INTERVAL_HOURS=24
